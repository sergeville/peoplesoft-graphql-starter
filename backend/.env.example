PORT=4000
# mock | integration-broker
PEOPLESOFT_DATA_SOURCE=mock

# -----------------------------------------------------------------------------
# Integration Broker REST (when PEOPLESOFT_DATA_SOURCE=integration-broker)
#
# In PeopleSoft you configure IB separately; here you only paste what PS publishes:
#
#   PeopleTools → Integration Broker
#     → Services → (e.g. EMPLOYEE_REST_API)
#     → Service Operations: GET /employees, GET /employee/{id}, etc.
#     → Gateway / Node security (Basic, OAuth, certificate)
#
# PS_BASE_URL = base URL for REST resources (no trailing slash), e.g.:
#   https://your-host/psc/ps/EMPLOYEE/HRMS/s/WEBLIB_EMP_REST.v1
# Local mock (npm run dev:mock-ps or Docker mock-ps service):
#   http://localhost:4100
#
# PS_USERNAME / PS_PASSWORD = service account PS team creates for the BFF
#   (not an end-user password from the browser)
# -----------------------------------------------------------------------------
PS_BASE_URL=https://your-peoplesoft-host/psc/ps/EMPLOYEE/HRMS/s/WEBLIB_REST
PS_USERNAME=
PS_PASSWORD=

# Mock dataset: auto | csv | sheet | generate
MOCK_DATA_SOURCE=auto
MOCK_EMPLOYEE_COUNT=1000
MOCK_EMPLOYEE_CSV_PATH=./data/employees.csv
# GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_ID/export?format=csv&gid=0

# Local mock IB server (copy to .env with dev:mock-ps — see .env.mock-ib.example)
# MOCK_IB_PORT=4100
# MOCK_IB_USERNAME=demo
# MOCK_IB_PASSWORD=demo
